# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Next.js build artifacts ──────────────────────────────────────────────────
# Rebuilt inside the container by `npm run build`.
.next
out

# ─── Environment files — NEVER bake secrets into the image ────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── Docker files (avoid recursive context) ───────────────────────────────────
Dockerfile*
docker-compose*
.dockerignore

# ─── Dev tooling configs (not needed at runtime) ──────────────────────────────
.eslintrc*
.eslintignore
.prettierrc*
.editorconfig
.vscode
.devcontainer
*.md
CHANGELOG*
LICENSE*

# ─── Test infrastructure ──────────────────────────────────────────────────────
__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
coverage
.nyc_output

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Playwright local browser cache ───────────────────────────────────────────
# These are the locally-downloaded binaries for development.
# The Docker image ships its own browsers at /ms-playwright.
playwright-browsers
